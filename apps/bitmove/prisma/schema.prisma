generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model profiles {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username          String?             @unique
  password_hash     String?
  full_name         String?
  avatar_url        String?
  role              user_role?          @default(user)
  timezone          String?             @default("Asia/Jakarta")
  level             Int?                @default(1)
  current_xp        Int?                @default(0)
  current_points    Int?                @default(0)
  streak_current    Int?                @default(0)
  streak_max        Int?                @default(0)
  last_active_date  DateTime?           @db.Date
  updated_at        DateTime?           @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  last_reset_date   DateTime?           @default(dbgenerated("(CURRENT_DATE - 1)")) @db.Date
  last_weekly_reset DateTime?           @default(dbgenerated("(CURRENT_DATE - 7)")) @db.Date
  exercise_library  exercise_library[]
  point_logs        point_logs[]
  rewards           rewards[]
  tasks             tasks[]
  training_programs training_programs[]
  workouts          workouts[]

  @@index([level], map: "idx_profiles_level")
}

model point_logs {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String    @db.Uuid
  xp_change     Int?      @default(0)
  points_change Int?      @default(0)
  source_type   String?
  description   String?
  created_at    DateTime? @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  profiles      profiles  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_point_logs_user")
}

model tasks {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String          @db.Uuid
  title             String
  category          String
  priority          task_priority?  @default(Medium)
  frequency         task_frequency? @default(Daily)
  target_value      Int?            @default(1)
  unit              String?         @default("Checklist")
  current_value     Int?            @default(0)
  is_completed      Boolean?        @default(false)
  last_completed_at DateTime?       @db.Timestamptz(6)
  created_at        DateTime?       @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  is_custom         Boolean?        @default(false)
  polarity          String          @default("POSITIVE") // "POSITIVE" = quest biasa, "NEGATIVE" = pantangan
  profiles          profiles        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, frequency, is_completed], map: "idx_tasks_user_freq")
}

model workouts {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String              @db.Uuid
  started_at          DateTime?           @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  ended_at            DateTime?           @db.Timestamptz(6)
  status              String?             @default("in_progress")
  total_xp_earned     Int?                @default(0)
  total_points_earned Int?                @default(0)
  notes               String?
  workout_exercises   workout_exercises[]
  profiles            profiles            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_workouts_user")
}

model rewards {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String    @db.Uuid
  title       String
  price       Int
  image_url   String?
  is_redeemed Boolean?  @default(false)
  created_at  DateTime? @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  profiles    profiles  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model level_rules {
  level  Int     @id
  min_xp Int
  title  String?
}

model task_library {
  id                   String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                String
  category             String
  default_priority     task_priority?  @default(Medium)
  default_frequency    task_frequency? @default(Daily)
  default_target_value Int?            @default(1)
  default_unit         String?         @default("Checklist")
  icon_emoji           String?
  polarity             String          @default("POSITIVE") // "POSITIVE" = objective, "NEGATIVE" = forbidden
}

model difficulty_scales {
  scale_type   scale_type_enum
  tier         tier_enum
  target_value Int

  @@id([scale_type, tier])
}

model tier_rewards {
  tier          tier_enum @id
  xp_reward     Int
  points_reward Int
}

model exercise_library {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String
  target_muscle     String?
  scale_type        scale_type_enum
  measurement_unit  String?             @default("reps")
  image_url         String?
  is_archived       Boolean?            @default(false)
  created_by        String?             @db.Uuid
  profiles          profiles?           @relation(fields: [created_by], references: [id], onDelete: Cascade, onUpdate: NoAction)
  program_schedules program_schedules[]
  workout_exercises workout_exercises[]
}

model workout_exercises {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workout_id  String           @db.Uuid
  exercise_id String           @db.Uuid
  notes       String?
  sets        sets[]
  exercises   exercise_library @relation(fields: [exercise_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  workouts    workouts         @relation(fields: [workout_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model sets {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workout_exercise_id String            @db.Uuid
  set_number          Int
  tier                tier_enum
  target_value        Int
  completed_value     Int?
  weight_kg           Float?            @default(0)
  is_completed        Boolean?          @default(false)
  workout_exercises   workout_exercises @relation(fields: [workout_exercise_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model program_schedules {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  program_id        String            @db.Uuid
  week_number       Int
  day_of_week       Int
  exercise_id       String            @db.Uuid
  target_tier       tier_enum
  notes             String?
  exercise_library  exercise_library  @relation(fields: [exercise_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  training_programs training_programs @relation(fields: [program_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([program_id, week_number, day_of_week], map: "idx_program_schedules_program")
}

model training_programs {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String              @db.Uuid
  title             String
  total_weeks       Int
  is_active         Boolean?            @default(true)
  start_date        DateTime?           @default(dbgenerated("CURRENT_DATE")) @db.Date
  created_at        DateTime?           @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  program_schedules program_schedules[]
  profiles          profiles            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, is_active], map: "idx_training_programs_user_active")
}

enum scale_type_enum {
  endurance
  strength
  power
  static_hold
  cardio_run
  mobility
}

enum task_frequency {
  Daily
  Weekly
  OneTime
}

enum task_priority {
  Low
  Medium
  High
}

enum tier_enum {
  D
  C
  B
  A
  S
  SS
}

enum user_role {
  user
  admin
}
